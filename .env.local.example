# ── AI ─────────────────────────────────────────────
GROQ_API_KEY=sua_chave_groq_aqui

# ── TTS ─────────────────────────────────────────────
ELEVENLABS_API_KEY=sua_chave_elevenlabs_aqui
ELEVENLABS_VOICE_ID=id_da_voz_aqui

# ── Spotify ─────────────────────────────────────────
SPOTIFY_CLIENT_ID=seu_client_id
SPOTIFY_CLIENT_SECRET=seu_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# ── Google Calendar ─────────────────────────────────
GOOGLE_CLIENT_ID=seu_client_id
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# ── Supabase (Memória Persistente) ───────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── GitHub ──────────────────────────────────────────
GITHUB_TOKEN=ghp_seu_personal_access_token
GITHUB_USER=seu_usuario_github
GITHUB_DEFAULT_REPO=nome_do_repo_padrao

# ── WhatsApp (Baileys — serviço local) ──────────────
WHATSAPP_SERVICE_URL=http://localhost:3001

# ── Clima — Briefing matinal (opcional) ─────────────
# Crie conta gratuita em openweathermap.org
OPENWEATHER_API_KEY=sua_chave_openweather
OPENWEATHER_CITY=São Paulo
